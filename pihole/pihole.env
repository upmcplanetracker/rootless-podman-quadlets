# Pi-hole environment file
# Location: ~/pihole/pihole.env
#
# SECURITY: chmod 600 ~/pihole/pihole.env
# This file contains your admin password — keep it readable only by your user.

# ── Required ──────────────────────────────────────────────────────────────────

# Timezone (https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
TZ=America/New_York

# Web interface admin password.
# If unset, Pi-hole assigns a random password (check logs: podman logs pihole).
FTLCONF_webserver_api_password=change-me-before-starting

# ── DNS ───────────────────────────────────────────────────────────────────────

# 'ALL' is required when using Podman's default pasta/slirp4netns networking
# so FTL listens on all interfaces, not just eth0.
FTLCONF_dns_listeningMode=ALL

# Upstream DNS servers (comma-separated). Defaults shown below (Cloudflare + Google).
# Examples: 8.8.8.8,8.8.4.4  /  9.9.9.9,149.112.112.112  /  127.0.0.1#5335 (Unbound)
#FTLCONF_dns_upstreams=1.1.1.1,8.8.8.8

# ── DHCP (optional) ───────────────────────────────────────────────────────────
# Uncomment the block below AND uncomment PublishPort=67:67/udp in the .container file.

#FTLCONF_dhcp_active=true
#FTLCONF_dhcp_start=192.168.1.100
#FTLCONF_dhcp_end=192.168.1.200
#FTLCONF_dhcp_router=192.168.1.1

# ── NTP (optional) ────────────────────────────────────────────────────────────
# Uncomment to have Pi-hole act as NTP server/client.
# Also uncomment PublishPort=123:123/udp in the .container file.

#FTLCONF_ntp_sync_active=true
#FTLCONF_ntp_ipv4_active=true

# ── Custom dnsmasq config (v5→v6 migration) ───────────────────────────────────
# Uncomment if you have files in etc-dnsmasq.d/ from a v5 install.
# Also uncomment the Volume line for etc-dnsmasq.d in the .container file.

#FTLCONF_misc_etc_dnsmasq_d=true
